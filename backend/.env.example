APP_NAME=FamilyHub API
APP_VERSION=1.0.0
ENVIRONMENT=development
APP_DEBUG=false

# Local fallback:
DATABASE_URL=sqlite:///./familyhub.db

# Docker MySQL:
# DATABASE_URL=mysql+mysqlconnector://familyhub_user:${MYSQL_PASSWORD}@mysql:3306/familyhub_db

REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=300

SECRET_KEY=replace-this-with-a-long-random-secret-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
SEED_ON_STARTUP=true
