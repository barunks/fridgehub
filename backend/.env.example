# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=FridgeHub API
APP_VERSION=1.0.0
# Set to "production" on Northflank — triggers security validators
ENVIRONMENT=production
APP_DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# Northflank: use the MySQL or PostgreSQL addon connection string
# MySQL (recommended — matches docker-compose)
DATABASE_URL=mysql+mysqlconnector://fridgehub_user:${MYSQL_PASSWORD}@mysql:3306/fridgehub_db
# PostgreSQL alternative
# DATABASE_URL=postgresql://fridgehub_user:${POSTGRES_PASSWORD}@localhost:5432/fridgehub_db
# SQLite — local dev only, never production
# DATABASE_URL=sqlite:///./fridgehub.db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Northflank: use the Redis addon connection string
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=300

# ── Auth & JWT ────────────────────────────────────────────────────────────────
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-this-with-a-long-random-secret-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Must be true in production (HTTPS only)
AUTH_COOKIE_SECURE=true
# Set to your Northflank app domain, e.g. fridgehub.northflank.app
# AUTH_COOKIE_DOMAIN=fridgehub.northflank.app
AUTH_COOKIE_SAMESITE=lax

# ── CORS ──────────────────────────────────────────────────────────────────────
# Northflank: set to your frontend service URL(s), comma-separated
# e.g. CORS_ORIGINS=https://fridgehub.northflank.app,https://www.fridgehub.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ── Startup behaviour ─────────────────────────────────────────────────────────
# Never seed in production — bootstrap via the /api/v1/auth/signup/bootstrap endpoint
SEED_ON_STARTUP=false
# Migrations are run by the backend_migrate service; keep false here
RUN_MIGRATIONS_ON_STARTUP=false

# ── Rate limiting ─────────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT_PER_MINUTE=10
# Set true to require deviceId on every login (recommended for production)
REQUIRE_DEVICE_ID_ON_LOGIN=false

# ── Limits (leave unset or empty for no restriction) ─────────────────────────
# MAX_DEVICES_PER_USER=5
# MAX_FAMILY_MEMBERS=10

# ── SMTP email (OTP delivery + invite emails) ─────────────────────────────────
# When unset, OTPs and invite emails are logged to console only (safe for dev)
# Northflank: store these as secret environment variables
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ── Twilio SMS (OTP delivery) ─────────────────────────────────────────────────
# When unset, SMS OTPs are logged to console only
# Users without a phone number skip SMS verification entirely
# Northflank: store these as secret environment variables
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# OTP SMS can use Twilio Verify with TWILIO_VERIFY_SID. In that mode, Twilio
# generates and checks the phone OTP, so TWILIO_FROM_NUMBER is not required.
# Programmable Messaging can use TWILIO_MESSAGING_SERVICE_SID / TWILIO_FROM_NUMBER.
TWILIO_VERIFY_SID=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MySQL (docker-compose only — Northflank uses addon env vars) ──────────────
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
